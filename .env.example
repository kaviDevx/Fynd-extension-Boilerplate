# ─── Extension Credentials ────────────────────────────────────────────────────
# From Fynd Partners panel → Extensions → Your Extension → API Credentials
EXTENSION_API_KEY=<your_api_key>
EXTENSION_API_SECRET=<your_api_secret>

# Public URL where this extension is hosted (must match Launch URL in Partners panel)
# For local dev: use ngrok or `fdk extension preview` tunnel URL
EXTENSION_BASE_URL=https://<your-tunnel>.ngrok.io

# Fynd API cluster (sandbox: https://api.fyndx0.de | production: https://api.fynd.com)
EXTENSION_CLUSTER_URL=https://api.fyndx0.de

# ─── Database ─────────────────────────────────────────────────────────────────
# fit key pattern: APP_IDENTIFIER = "fynd-extension-boilerplate"
#   → underscored: "fynd_extension_boilerplate"
#   → env var:     MONGO_FYND_EXTENSION_BOILERPLATE_READ_WRITE
MONGO_FYND_EXTENSION_BOILERPLATE_READ_WRITE=mongodb://localhost:27017/fynd-extension-boilerplate
REDIS_FYND_EXTENSION_BOILERPLATE_READ_WRITE=redis://localhost:6379/0

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
MODE=server

# FDK debug logging — logs every HTTP call FDK makes as a curl command + full token response.
# Extremely useful when debugging auth/install issues, very noisy otherwise.
# Default: false. Set to true only when troubleshooting.
FDK_DEBUG=false

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# NEW RELIC: fit/tracing requires a non-empty app name or it will print a warning.
# Set this even in dev — use any descriptive string.
NEW_RELIC_APP_NAME=fynd-extension-boilerplate-dev
NEW_RELIC_LICENSE_KEY=
